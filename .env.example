# LINE Proxy Environment Configuration Example
# Copy these to your ~/.hermes/.env or project .env file

# =============================================================================
# AI CONFIGURATION
# =============================================================================
# The display name of the human owner (used for AI attribution)
LINE_OWNER_NAME="YourName"

# Default Gemini model to use for the proxy engine
# Recommended: gemini-3-flash-preview or gemini-2.0-flash-exp
LINE_DEFAULT_MODEL="gemini-3-flash-preview"

# =============================================================================
# INFRASTRUCTURE
# =============================================================================
# Hermes API Server URL for tool execution
HERMES_API_URL="http://127.0.0.1:8642"

# =============================================================================
# REQUIRED API KEYS (In ~/.hermes/.env)
# =============================================================================
# GOOGLE_API_KEY=your_api_key_here
